{
    "workbench.colorTheme": "Dark Modern",
    "ruby.lint": {
        "rubocop": {
            "command": "rubocop",  // setting this will override automatic detection
            "useBundler": true,
            "lint": true, // enable lint cops
            // "only": ["array", "of", "cops", "to", "run"],
            "except": ["array", "of", "cops", "not", "to", "run"]
            // "require": ["array", "of", "ruby", "files", "to", "require"],
            // "rails": true // requires rubocop-rails gem for RuboCop >= 0.72.0
          }
    },
    "editor.tabSize": 2,
    "editor.wordWrapColumn": 120,
    "files.trimTrailingWhitespace": true,
    "files.trimFinalNewlines": true,
    "eslint.packageManager": "yarn",
    "eslint.run": "onSave",
    "ruby.rubocop.suppressRubocopWarnings": true,
    "editor.rulers": [
        120
    ],
    "editor.scrollBeyondLastLine": false,
    "workbench.editor.wrapTabs": true,
    "sqltools.autoOpenSessionFiles": false,
    "sqltools.highlightQuery": false,
    "search.seedOnFocus": true,
    "[sql]": {
        "editor.defaultFormatter": "mtxr.sqltools"
    },
    "files.insertFinalNewline": true,
    "security.workspace.trust.untrustedFiles": "open",
    "gitlens.currentLine.enabled": false,
    "gitlens.hovers.currentLine.over": "line",
    "gitlens.codeLens.enabled": false,
    "workbench.editor.decorations.colors": false,
    "yaml.schemas": {
        "file:///Users/swrathall/.vscode/extensions/atlassian.atlascode-3.8.3/resources/schemas/pipelines-schema.json": "bitbucket-pipelines.yml"
    },
    "redhat.telemetry.enabled": false,
    "atlascode.bitbucket.explorer.notifications.pullRequestCreated": false,
    "atlascode.bitbucket.pipelines.monitorEnabled": false,
    "atlascode.jira.explorer.monitorEnabled": false,
    "atlascode.bitbucket.issues.monitorEnabled": false,
    "yaml.customTags": [
        "!And",
        "!And sequence",
        "!If",
        "!If sequence",
        "!Not",
        "!Not sequence",
        "!Equals",
        "!Equals sequence",
        "!Or",
        "!Or sequence",
        "!FindInMap",
        "!FindInMap sequence",
        "!Base64",
        "!Join",
        "!Join sequence",
        "!Cidr",
        "!Ref",
        "!Sub",
        "!Sub sequence",
        "!GetAtt",
        "!GetAZs",
        "!ImportValue",
        "!ImportValue sequence",
        "!Select",
        "!Select sequence",
        "!Split",
        "!Split sequence"
    ],
    "aws.suppressPrompts": {
        "regionAddAutomatically": true
    },
    "workbench.startupEditor": "none",
    "gitlens.ai.model": "vscode",
    "gitlens.ai.vscode.model": "copilot:gpt-4.1",
    "gitlens.blame.format": "${author|12-} ${agoOrDate|14-}",
    "gitlens.heatmap.hotColor": "#ffffff",
    "gitlens.heatmap.coldColor": "#0a1af6",
    "workbench.settings.applyToAllProfiles": [
        "gitlens.heatmap.coldColor",
        "gitlens.heatmap.hotColor",
        "gitlens.heatmap.ageThreshold"
    ],
    "gitlens.heatmap.ageThreshold": 365,
    "claudeCode.preferredLocation": "sidebar",
    "gitlens.blame.highlight.locations": [
        "gutter",
        "overview"
    ],
    "rest-client.previewOption": "exchange",
    // Required for the httpYac extension to honour the QuotaGuard proxy that the valiant repo's
    // httpyac.config.js applies to HTTP requests:
    "http.proxySupport": "on",
    "gitlens.hovers.currentLine.enabled": false,
    "mermaidChart.showGenerateDiagramCodeLens": false,
    "chat.viewSessions.orientation": "stacked",
    "github.copilot.enable": {
        "*": true,
        "plaintext": false,
        "markdown": false,
        "scminput": false,
        "ruby": true
    },
    "workbench.browser.openLocalhostLinks": false,
    "rubyLsp.enabledFeatures": {
        "codeActions": true,
        "diagnostics": true,
        "documentHighlights": true,
        "documentLink": true,
        "documentSymbols": true,
        "foldingRanges": true,
        "formatting": true,
        "hover": true,
        "inlayHint": true,
        "onTypeFormatting": true,
        "selectionRanges": true,
        "semanticHighlighting": true,
        "completion": true,
        "codeLens": false,
        "definition": true,
        "workspaceSymbol": true,
        "signatureHelp": true,
        "typeHierarchy": true
    }
}
